# ─────────────────────────────────────────────────────────────────
# OBSTRECTED — Environment Variables (copy to .env for production)
# ─────────────────────────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=production

# Your deployed app URL (used to generate QR Codes in confirmation emails)
# e.g. https://obstrected.onrender.com
BASE_URL=https://your-domain.com

# Session secret — change this to a long random string in production!
SESSION_SECRET=your_super_secret_session_key_here
